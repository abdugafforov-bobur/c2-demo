<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Allow cleartext for training server (HTTP). In production apps
         this would normally be HTTPS only. For the training demo we
         allow plain HTTP so you can run a simple listener. -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
